{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "adhocore/jwt": "^1.1.4",
        "artesaos/seotools": "^1.4.1",
        "awcodes/filament-curator": "^4.0.8",
        "awcodes/overlook": "^3.0.3",
        "bezhansalleh/filament-shield": "^4.2",
        "filament/filament": "^4.11.7",
        "intervention/image": "^3.11.8",
        "laravel-lang/common": "^6.8.0",
        "laravel/framework": "^13.15",
        "laravel/jetstream": "^5.5.3",
        "laravel/sanctum": "^4.3.2",
        "laravel/tinker": "^3.0.2",
        "livewire/livewire": "^3.8.1",
        "shuvroroy/filament-spatie-laravel-backup": "^3.4",
        "solution-forest/filament-translate-field": "^2.1.3",
        "spatie/color": "^1.8.0",
        "spatie/laravel-data": "^4.23.0",
        "spatie/laravel-google-fonts": "^1.6.0",
        "spatie/laravel-honeypot": "^4.7.1",
        "spatie/laravel-robots-middleware": "^1.4.2",
        "spatie/laravel-sitemap": "^7.4.0",
        "spatie/laravel-translatable": "^6.14.1"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7.0",
        "fakerphp/faker": "^1.24.1",
        "fruitcake/laravel-debugbar": "^4.3",
        "larastan/larastan": "^3.10.0",
        "laravel/pail": "^1.2.7",
        "laravel/pint": "^1.29.1",
        "laravel/sail": "^1.62.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "phpunit/phpunit": "^11.5.55"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "dev:host": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve --host 0.0.0.0\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev:host\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "npm run build",
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "@php artisan config:clear",
            "@php artisan clear-compiled",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
